{
  "id": "mangayabu",
  "name": "MangaYabu",
  "baseUrl": "https://mangayabu.top",
  "version": "1.0.0",
  "language": "pt-BR",
  "iconUrl": "https://mangayabu.top/favicon.ico",
  "search": {
    "urlPattern": "/?s={query}",
    "method": "GET",
    "selectors": {
      "container": ".listupd article",
      "title": ".tt span",
      "cover": "img",
      "coverAttr": "src",
      "url": "a",
      "urlAttr": "href"
    }
  },
  "details": {
    "selectors": {
      "title": ".entry-title",
      "description": "[itemprop='description'] p, .synp p",
      "author": ".fmed:contains('Autor') span, .fmed:contains('Author') span",
      "status": ".imptdt:contains('Status') i",
      "genres": ".mgen a",
      "cover": ".thumb img",
      "coverAttr": "src"
    }
  },
  "chapters": {
    "selectors": {
      "container": "#chapterlist ul li",
      "title": ".chapternum",
      "date": ".chapterdate",
      "url": "a",
      "urlAttr": "href"
    },
    "numberRegex": "Cap(?:ítulo)?[\\s.:\\-]*(\\d+(?:\\.\\d+)?)"
  },
  "pages": {
    "mode": "DOM",
    "selectors": {
      "container": "#readerarea",
      "image": "img.ts-main-image, img[decoding='async']",
      "imageAttr": "src"
    }
  }
}